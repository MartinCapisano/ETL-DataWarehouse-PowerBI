    <DTS:Executable
      DTS:refId="Package\Formalizacion BIRHT_DATE"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Tarea Ejecutar SQL"
      DTS:DTSID="{DF612361-7621-4DA6-8147-0DA0CDDBD0EF}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Formalizacion BIRHT_DATE"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="2">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{69DE55A5-17C3-404F-B31E-7938F3514F15}"
          SQLTask:SqlStatementSource="WHILE EXISTS (&#xA;    SELECT 1&#xA;    FROM Stg_Customers&#xA;    WHERE PATINDEX('%[^0-9/]%', BIRTH_DATE) &gt; 0&#xA;)&#xA;BEGIN&#xA;&#xA;    UPDATE Stg_Customers&#xA;    SET BIRTH_DATE = STUFF(&#xA;        BIRTH_DATE,&#xA;        PATINDEX('%[^0-9/]%', BIRTH_DATE),&#xA;        1,&#xA;        ''&#xA;    )&#xA;    WHERE PATINDEX('%[^0-9/]%', BIRTH_DATE) &gt; 0&#xA;&#xA;END&#xA;&#xA;&#xA;UPDATE Stg_Customers&#xA;SET BIRTH_DATE = NULL&#xA;WHERE&#xA;    TRY_CONVERT(int, LEFT(BIRTH_DATE, CHARINDEX('/', BIRTH_DATE) - 1)) &gt; 31&#xA;&#xA;    OR&#xA;&#xA;    TRY_CONVERT(&#xA;        int,&#xA;        SUBSTRING(&#xA;            BIRTH_DATE,&#xA;            CHARINDEX('/', BIRTH_DATE) + 1,&#xA;            CHARINDEX('/', BIRTH_DATE, CHARINDEX('/', BIRTH_DATE) + 1)&#xA;            - CHARINDEX('/', BIRTH_DATE) - 1&#xA;        )&#xA;    ) &gt; 31" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
