        <SQLTask:SqlTaskData
          SQLTask:Connection="{69DE55A5-17C3-404F-B31E-7938F3514F15}"
          SQLTask:SqlStatementSource="ALTER TABLE Stg_BillingHist&#xA;ALTER COLUMN customer_id INT;&#xA;&#xA;ALTER TABLE Stg_BillingHist&#xA;ALTER COLUMN employee_id INT;&#xA;&#xA;ALTER TABLE Stg_BillingHist&#xA;ALTER COLUMN product_id INT;&#xA;&#xA;ALTER TABLE Stg_BillingHist&#xA;ALTER COLUMN quantity INT;&#xA;&#xA;ALTER TABLE Stg_BillingHist&#xA;ALTER COLUMN branch_id INT;&#xA;&#xA;DELETE FROM Stg_BillingHist&#xA;WHERE date IS NULL&#xA;   OR customer_id IS NULL&#xA;   OR employee_id IS NULL;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
