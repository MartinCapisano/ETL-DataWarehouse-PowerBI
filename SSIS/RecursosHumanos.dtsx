    <DTS:Executable
      DTS:refId="Package\Formalizar Birth_Date"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Tarea Ejecutar SQL"
      DTS:DTSID="{66E4C987-8290-485E-AC9E-F08D0DFC9787}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Formalizar Birth_Date"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{69DE55A5-17C3-404F-B31E-7938F3514F15}"
          SQLTask:SqlStatementSource="WHILE EXISTS (&#xA;    SELECT 1&#xA;    FROM Stg_Employees&#xA;    WHERE PATINDEX('%[^0-9/]%', BIRTH_DATE) &gt; 0&#xA;)&#xA;BEGIN&#xA;&#xA;    UPDATE Stg_Employees&#xA;    SET BIRTH_DATE = STUFF(&#xA;        BIRTH_DATE,&#xA;        PATINDEX('%[^0-9/]%', BIRTH_DATE),&#xA;        1,&#xA;        ''&#xA;    )&#xA;    WHERE PATINDEX('%[^0-9/]%', BIRTH_DATE) &gt; 0&#xA;&#xA;END&#xA;&#xA;&#xA;UPDATE Stg_Employees&#xA;SET BIRTH_DATE = NULL&#xA;WHERE&#xA;    TRY_CONVERT(int, LEFT(BIRTH_DATE, CHARINDEX('/', BIRTH_DATE) - 1)) &gt; 31&#xA;&#xA;    OR&#xA;&#xA;    TRY_CONVERT(&#xA;        int,&#xA;        SUBSTRING(&#xA;            BIRTH_DATE,&#xA;            CHARINDEX('/', BIRTH_DATE) + 1,&#xA;            CHARINDEX('/', BIRTH_DATE, CHARINDEX('/', BIRTH_DATE) + 1)&#xA;            - CHARINDEX('/', BIRTH_DATE) - 1&#xA;        )&#xA;    ) &gt; 31&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Formalizar Employment_Date"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Tarea Ejecutar SQL"
      DTS:DTSID="{20be6d91-263a-4cce-bb3e-2facc0ab3960}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Formalizar Employment_Date"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{69DE55A5-17C3-404F-B31E-7938F3514F15}"
          SQLTask:SqlStatementSource="WHILE EXISTS (&#xA;    SELECT 1&#xA;    FROM Stg_Employees&#xA;    WHERE PATINDEX('%[^0-9/]%', EMPLOYMENT_DATE) &gt; 0&#xA;)&#xA;BEGIN&#xA;&#xA;    UPDATE Stg_Employees&#xA;    SET EMPLOYMENT_DATE = STUFF(&#xA;        EMPLOYMENT_DATE,&#xA;        PATINDEX('%[^0-9/]%', EMPLOYMENT_DATE),&#xA;        1,&#xA;        ''&#xA;    )&#xA;    WHERE PATINDEX('%[^0-9/]%', EMPLOYMENT_DATE) &gt; 0&#xA;&#xA;END&#xA;&#xA;&#xA;UPDATE Stg_Employees&#xA;SET EMPLOYMENT_DATE = NULL&#xA;WHERE&#xA;    TRY_CONVERT(int, LEFT(EMPLOYMENT_DATE, CHARINDEX('/', EMPLOYMENT_DATE) - 1)) &gt; 31&#xA;&#xA;    OR&#xA;&#xA;    TRY_CONVERT(&#xA;        int,&#xA;        SUBSTRING(&#xA;            EMPLOYMENT_DATE,&#xA;            CHARINDEX('/', EMPLOYMENT_DATE) + 1,&#xA;            CHARINDEX('/', EMPLOYMENT_DATE, CHARINDEX('/', EMPLOYMENT_DATE) + 1)&#xA;            - CHARINDEX('/', EMPLOYMENT_DATE) - 1&#xA;        )&#xA;    ) &gt; 31&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
