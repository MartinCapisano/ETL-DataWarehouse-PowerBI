    <DTS:Executable
      DTS:refId="Package\Correccion fechas"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Tarea Ejecutar SQL"
      DTS:DTSID="{34050D06-150F-4C94-B080-72D4C627B874}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Correccion fechas"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{7D71A68A-9D8C-4F37-B83A-FEED33B17E41}"
          SQLTask:SqlStatementSource="UPDATE Stg_Stock&#xA;SET [DATE] =&#xA;    CONVERT(&#xA;        VARCHAR(30),&#xA;&#xA;        CASE&#xA;&#xA;            WHEN SUBSTRING(REPLACE(LOWER([DATE]),'.',''),15,2) = '60'&#xA;             AND SUBSTRING(REPLACE(LOWER([DATE]),'.',''),18,2) = '60'&#xA;            THEN DATEADD(&#xA;                    SECOND,1,&#xA;                    DATEADD(&#xA;                        MINUTE,1,&#xA;                        TRY_CONVERT(&#xA;                            DATETIME,&#xA;                            STUFF(&#xA;                                STUFF(REPLACE(LOWER([DATE]),'.',''),15,2,'00'),&#xA;                                18,2,'00'&#xA;                            ),&#xA;                            101&#xA;                        )&#xA;                    )&#xA;                 )&#xA;&#xA;            WHEN SUBSTRING(REPLACE(LOWER([DATE]),'.',''),15,2) = '60'&#xA;            THEN DATEADD(&#xA;                    MINUTE,1,&#xA;                    TRY_CONVERT(&#xA;                        DATETIME,&#xA;                        STUFF(REPLACE(LOWER([DATE]),'.',''),15,2,'00'),&#xA;                        101&#xA;                    )&#xA;                 )&#xA;&#xA;            WHEN SUBSTRING(REPLACE(LOWER([DATE]),'.',''),18,2) = '60'&#xA;            THEN DATEADD(&#xA;                    SECOND,1,&#xA;                    TRY_CONVERT(&#xA;                        DATETIME,&#xA;                        STUFF(REPLACE(LOWER([DATE]),'.',''),18,2,'00'),&#xA;                        101&#xA;                    )&#xA;                 )&#xA;&#xA;            ELSE TRY_CONVERT(&#xA;                    DATETIME,&#xA;                    REPLACE(LOWER([DATE]),'.',''),&#xA;                    101&#xA;                 )&#xA;&#xA;        END,&#xA;&#xA;        120&#xA;    )&#xA;WHERE [DATE] LIKE '%.%';" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
